# Vercel environment variables for the contact form

# SendGrid API key used to send outgoing emails.
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# Verified sender email address in SendGrid.
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Destination inbox for form submissions.
CONTACT_EMAIL=you@example.com

# Google reCAPTCHA settings
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY

# Optional: enable server-side logging when troubleshooting
ENABLE_CONTACT_LOGGING=false
